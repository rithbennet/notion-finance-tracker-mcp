NOTION_API_KEY=secret_xxx

# Required data-source IDs for querying.
NOTION_EXPENSES_DATA_SOURCE_ID=your_expenses_data_source_id
NOTION_BUDGET_DATA_SOURCE_ID=your_budget_data_source_id
NOTION_INCOMES_DATA_SOURCE_ID=your_incomes_data_source_id
NOTION_ACCOUNTS_DATA_SOURCE_ID=your_accounts_data_source_id
NOTION_TRANSFERS_DATA_SOURCE_ID=your_transfers_data_source_id
NOTION_SUBSCRIPTIONS_DATA_SOURCE_ID=your_subscriptions_data_source_id
NOTION_GOALS_DATA_SOURCE_ID=your_goals_data_source_id
NOTION_MONTHS_DATA_SOURCE_ID=your_months_data_source_id

# Required database IDs for creating pages.
NOTION_EXPENSES_DATABASE_ID=your_expenses_database_id
NOTION_INCOMES_DATABASE_ID=your_incomes_database_id
NOTION_TRANSFERS_DATABASE_ID=your_transfers_database_id

# Required when the MCP is exposed remotely on Cloudflare Workers.
FINANCE_MCP_BEARER_TOKEN=change_me

FINANCE_MCP_AUDIT_LOG=logs/finance-mcp-audit.jsonl
